{
  "$schema": "https://dl.viam.dev/module.schema.json",
  "module_id": "viam-soleng:data-mirror",
  "visibility": "public",
  "url": "https://github.com/viam-soleng/viam-data-mirror",
  "description": "Mirror binary data from Viam data management to any machines running viam-server",
  "models": [
    {
      "api": "rdk:service:generic",
      "model": "viam-soleng:data:mirror"
    }
  ],
  "build": {
    "build": "make module.tar.gz",
    "setup": "make setup",
    "path": "module.tar.gz",
    "arch": ["linux/amd64", "linux/arm64", "darwin/arm64"]
  },
  "entrypoint": "bin/viam-data-mirror"
}
